# =============================================================================
# MealfitRD backend — .env.example
# =============================================================================
# Copia este archivo a `.env` y rellena los valores. **NUNCA commitees `.env`**.
# Producción: inyecta estas variables via las env vars del VPS Oracle en lugar
# de copiar `.env` al contenedor.
#
# CHECKLIST de rotación de secretos (hacer una vez al ir a producción real):
#   [ ] Supabase: regenerar `service_role` JWT en Project Settings → API
#   [ ] Supabase DB: rotar password del usuario `postgres` (Project → Database)
#   [ ] DeepSeek: rotar DEEPSEEK_API_KEY (platform.deepseek.com → API keys);
#       revocar la GEMINI_API_KEY legacy en Google AI Studio si sigue activa
#   [ ] PayPal: regenerar Client Secret (Developer Dashboard → My Apps)
#   [ ] ElevenLabs: regenerar API key (Profile → API Keys)
#   [ ] VAPID: regenerar par via `npx web-push generate-vapid-keys`
#       (NB: rotar VAPID invalida las suscripciones push existentes)
#   [ ] Sentry: rotar DSN si fue expuesto (Project Settings → Client Keys)
#   [ ] WEBHOOK_SECRET: regenerar con `openssl rand -hex 32`
# =============================================================================

# ----- Base de datos: Neon Postgres ------------------------------------------
# [P1-NEON-DB-MIGRATION] Supabase eliminado por completo. Ambas vars requeridas:
#   NEON_DATABASE_URL        — endpoint DIRECTO (session mode) → chat_checkpoint_pool
#   NEON_DATABASE_URL_POOLED — pooler PgBouncer (transaction mode) → pools principales
# MEALFIT_DB_BACKEND default "neon" (único backend soportado).
NEON_DATABASE_URL="postgresql://<user>:<password>@<ep-id>.<region>.aws.neon.tech/<db>?sslmode=require"
NEON_DATABASE_URL_POOLED="postgresql://<user>:<password>@<ep-id>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"

# ----- LLM provider ----------------------------------------------------------
# [P0-DEEPSEEK-MIGRATION · 2026-06-12] DeepSeek V4 (API OpenAI-compatible,
# base https://api.deepseek.com). Router por tier de suscripción:
#   gratis → deepseek-v4-flash · basic/plus/ultra → deepseek-v4-pro
# Overrides opcionales: MEALFIT_MODEL_FREE_TIER / MEALFIT_MODEL_PAID_TIER /
# MEALFIT_DEEPSEEK_BASE_URL (ver llm_provider.py).
DEEPSEEK_API_KEY=<deepseek-platform-api-key>

# ----- Embeddings provider: Cohere Embed v4 ----------------------------------
# [P1-COHERE-EMBED-V4 · 2026-06-12] Default: provider=cohere, model=embed-v4.0,
# dimensión 1536 (= columnas pgvector tras p1_cohere_embed_v4_vector_dims).
# SIN esta key el sistema degrada limpio a keyword/recency (gating por
# presencia de key) — setearla es el ÚNICO paso de activación.
COHERE_API_KEY=<cohere-api-key>
# Overrides opcionales (ver embeddings_provider.py):
# MEALFIT_EMBEDDINGS_PROVIDER=cohere            # cohere|openai_compatible|disabled
# MEALFIT_EMBEDDINGS_MODEL=embed-v4.0
# MEALFIT_EMBEDDINGS_DIMENSION=1536             # 256|512|1024|1536 (cambiar exige migrar pgvector)
# Rollback a cualquier endpoint /embeddings estilo OpenAI:
# MEALFIT_EMBEDDINGS_PROVIDER=openai_compatible
# MEALFIT_EMBEDDINGS_BASE_URL=<base-url>
# EMBEDDINGS_API_KEY=<key>

# ----- Vision provider (pendiente — DeepSeek V4 no acepta imágenes) ----------
# Default `disabled`: Diario Visual / "Escanear comida" responden
# analysis_failed (soft-fail). Para activar un modelo con visión:
# MEALFIT_VISION_PROVIDER=openai_compatible
# MEALFIT_VISION_BASE_URL=<base-url>
# MEALFIT_VISION_MODEL=<model-id-con-vision>
# VISION_API_KEY=<key>

# ----- FastAPI runtime -------------------------------------------------------
PORT=3001
ENVIRONMENT=production

# ----- Webhooks internos (HMAC) ----------------------------------------------
# Genera con: openssl rand -hex 32
WEBHOOK_SECRET=<random-hex-32>

# ----- Sesión first-party (__Host-mf_session) [P1-FIRST-PARTY-SESSION] --------
# Secreto HS256 con el que el backend firma la cookie de sesión first-party que
# permite a iOS PWA conservar la sesión al cerrar la app (Neon sirve su cookie
# third-party → iOS la borra). DEBE tener >=32 chars o la feature queda OFF
# (fail-secure → Bearer-only, sin regresión). Genera con: openssl rand -hex 48
MEALFIT_SESSION_SECRET=<random-hex-48>
# Rotación (opcional): durante una rotación, pon el secreto VIEJO aquí un período
# de gracia para no desloguear a todos; vacíalo después.
# MEALFIT_SESSION_SECRET_OLD=
# Opcionales (defaults seguros): TTL deslizante 30d, cap absoluto 90d.
# MEALFIT_SESSION_TTL_DAYS=30
# MEALFIT_SESSION_ABS_MAX_DAYS=90

# ----- PayPal (backend valida subscripciones server-side) --------------------
PAYPAL_CLIENT_ID=<paypal-client-id>
PAYPAL_SECRET=<paypal-client-secret>
PAYPAL_WEBHOOK_ID=<paypal-webhook-id>

# [P0-BILLING-1 · 2026-05-12] Mapping plan_id (PayPal) → tier interno.
# Backend deriva tier server-side; el cliente NO puede inyectar tier en
# /api/subscription/verify. Las vars SON OBLIGATORIAS en producción —
# sin ellas, /verify rechaza con 400 "Plan no reconocido" tras matchear
# status=ACTIVE en PayPal. Obtener cada plan_id en PayPal Developer
# Dashboard → Products & Plans.
PAYPAL_PLAN_BASIC_ID=<paypal-plan-id-basic>
PAYPAL_PLAN_PLUS_ID=<paypal-plan-id-plus>
PAYPAL_PLAN_ULTRA_ID=<paypal-plan-id-ultra>
# [P1-BILLING-ANNUAL-MAP] Plan IDs ANUALES — OBLIGATORIOS si vendes suscripción
# anual (la UI ofrece anual para Básico y Plus; Ultra/Max es monthly-only).
# El backend los lee en _build_paypal_plan_tier_map(); si FALTAN, una compra
# ANUAL cobra en PayPal y luego /verify responde 400 "Plan no reconocido" →
# COBRO SIN UPGRADE (posible chargeback). Deben coincidir con los VITE_PAYPAL_
# PLAN_*_ANNUAL del frontend.
PAYPAL_PLAN_BASIC_ANNUAL_ID=<paypal-plan-id-basic-annual>
PAYPAL_PLAN_PLUS_ANNUAL_ID=<paypal-plan-id-plus-annual>
# PAYPAL_PLAN_ULTRA_ANNUAL_ID=<paypal-plan-id-ultra-annual>  # solo si reactivas Ultra anual

# [P0-BILLING-2 · 2026-05-12] DEV-ONLY: permite bypass de verificación PayPal
# cuando faltan PAYPAL_CLIENT_ID/PAYPAL_SECRET. Por DEFAULT FALSE.
# NUNCA setear a true en producción — el endpoint /verify ya gate-ea por
# ENVIRONMENT=production AND no bypass → 503. Esta var existe solo para
# desarrollo local sin credenciales PayPal reales.
# MEALFIT_ALLOW_PAYPAL_BYPASS=false

# ----- Observabilidad --------------------------------------------------------
SENTRY_DSN=<sentry-dsn-backend>

# [P1-SENTRY-SAMPLE-COST · 2026-05-12] Sampling de Sentry (traces y profiling).
# Default código = 0.1 (10%). Subir a 1.0 SOLO si necesitas debug intensivo
# de un deploy específico; el costo Sentry escala lineal con sample rate y a
# 1.0 + tráfico moderado se agota la cuota mensual en horas (los errores que
# necesitas son los primeros throttled). Clamp [0.0, 1.0]; valores fuera de
# rango caen al default. Auto-registrado en _KNOBS_REGISTRY → /health/version.
# MEALFIT_SENTRY_TRACES_SAMPLE_RATE=0.1
# MEALFIT_SENTRY_PROFILES_SAMPLE_RATE=0.1

# ----- Web Push (VAPID) ------------------------------------------------------
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_CLAIM_EMAIL=mailto:soporte@<your-domain>

# ----- Voice (TTS) -----------------------------------------------------------
ELEVENLABS_API_KEY=<elevenlabs-api-key>

# =============================================================================
# Knobs operacionales (MEALFIT_*) — opcionales con defaults seguros en código.
# Solo listados los overrides recomendados para producción. La lista completa
# se autorregistra en `_KNOBS_REGISTRY` (graph_orchestrator.py) y se expone
# via /health/version.
#
# [P2-KNOBS-OPERATIONAL-DOC · 2026-05-23] Guía completa de descubrimiento +
# knobs de alto valor para producción + cómo añadir uno nuevo:
#   → backend/docs/knobs_reference.md
# Quick checks at runtime:
#   curl /health/version | jq '.knobs_registered_count'
#   python -c "from graph_orchestrator import get_knobs_registry_snapshot;
#              print(sorted(get_knobs_registry_snapshot().keys()))"
# =============================================================================

# --- DB pool (subidos sobre defaults código min=2/max=30/timeout=30s para
#     absorber cron + chunks + meta-learning concurrentes). -------------------
MEALFIT_DB_POOL_MIN_SIZE=10
MEALFIT_DB_POOL_MAX_SIZE=60
MEALFIT_DB_POOL_TIMEOUT_S=10

# --- Self-critique fix timeout (default código 180s; bajado a 120s para
#     limitar bloqueo cuando Gemini está flap). ------------------------------
MEALFIT_CRITIQUE_FIX_TIMEOUT_S=120

# --- Embeddings: cooldown tras 429 + batching del cache init ---------------
MEALFIT_SEMANTIC_INIT_FAIL_COOLDOWN_S=600
MEALFIT_EMBED_INIT_BATCH_SIZE=10
MEALFIT_EMBED_INIT_BATCH_DELAY_S=1.5
# (Los knobs MEALFIT_GEMINI_EMBEDDING_* fueron eliminados en P0-DEEPSEEK-MIGRATION;
#  el modelo de embeddings vive ahora en MEALFIT_EMBEDDINGS_MODEL, ver arriba.)

# --- Pro fallback para self-critique ---------------------------------------
MEALFIT_CRITIQUE_PRO_FALLBACK_ENABLED=True
MEALFIT_CRITIQUE_PRO_FALLBACK_TIMEOUT_S=120

# --- Chunk proactive margin -------------------------------------------------
CHUNK_PROACTIVE_MARGIN_DAYS=1

# --- Motor de precisión de macros (cerebro dividido determinista) -----------
# [gap-audit G7 · 2026-06-15] DEFAULTS DE CÓDIGO = False (solver) → SIN estas vars el plan revierte al
# balancing "a ojo" del LLM (proteína ~16% MAPE, ~24% días en banda). DEBEN estar en True en producción;
# un check de arranque emite el system_alert `macro_engine_disabled_in_prod` si MACRO_SOLVER_ENABLED es
# False en ENVIRONMENT=production. El override per-feature siempre gana sobre el router por tier.
MEALFIT_MACRO_SOLVER_ENABLED=True
MEALFIT_MACRO_AWARE_RECONCILE=True
MEALFIT_MACRO_POSTQUANT_RECONCILE=True
MEALFIT_BAND_SCORE_GATE=True
# Rollback sin redeploy: poner cualquiera en False. Carb-trim (corrector legacy unidireccional) opcional:
# MEALFIT_CARB_TARGET_TRIM=False  (superseded por MACRO_POSTQUANT_RECONCILE, que es bidireccional)
